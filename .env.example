# ============================================================================
# Mosaico — camada de integração Azzas · variáveis de ambiente (TEMPLATE)
# ============================================================================
# Copie para `.env.local` e preencha. NUNCA commitar segredos reais.
# Este arquivo só contém PLACEHOLDERS.

# --- Seleção de fonte de dados (o "um arquivo" do swap vive em lib/data) ---
# mock = dados fictícios (default neste milestone) | mcp = MCP/BigQuery real (M2)
DATA_SOURCE=mock

# --- Seleção da fonte de tarefas (commodity; default mock, Plane no futuro) ---
TASK_SOURCE=mock

# --- MCP / dados reais (MILESTONE 2 — deixe vazio agora) ---
# URL base dos agentes MCP Azzas (ex.: serviço HTTP). Sem valor no starter.
MCP_BASE_URL=
# Token/credencial de acesso ao MCP — SEMPRE via env, nunca no código.
MCP_API_TOKEN=
# Alternativa BigQuery direto: JSON da service account (NUNCA commitar).
GOOGLE_SERVICE_ACCOUNT_JSON=

# --- Auth (MILESTONE de auth — forma Auth.js + Microsoft Entra) ---
AUTH_SECRET=
AUTH_MICROSOFT_ENTRA_ID_ID=
AUTH_MICROSOFT_ENTRA_ID_SECRET=
AUTH_MICROSOFT_ENTRA_ID_ISSUER=
